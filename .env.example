# Copy this file to .env before starting the project.
# Root .env is the only main config file for local development and Docker Compose.

# Required: Alibaba Bailian / DashScope API key.
AI_BAILIAN_API_KEY=replace_with_your_api_key

# Optional AI model.
AI_MODEL=qwen3.6-plus

# Backend HTTP port.
SERVER_PORT=8081

# PostgreSQL for local bootRun.
# Docker maps host port 5433 to container port 5432 to avoid conflicts with a local PostgreSQL.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_HOST_PORT=5433
POSTGRES_DB=health_guardian
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

# Redis for local bootRun.
REDIS_HOST=localhost
REDIS_PORT=6380

# MinIO / S3-compatible storage for local bootRun.
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=change-me-access-key
APP_STORAGE_SECRET_KEY=change-me-secret-key
APP_STORAGE_BUCKET=health-guardian
APP_STORAGE_REGION=us-east-1

# Structured output retries.
APP_AI_STRUCTURED_MAX_ATTEMPTS=2
APP_AI_STRUCTURED_INCLUDE_LAST_ERROR=true

# Consultation defaults.
APP_CONSULTATION_FOLLOW_UP_COUNT=1
APP_CONSULTATION_EVALUATION_BATCH_SIZE=8

# LightRAG integration (enabled by default).
# lightrag/.env is required for the LightRAG container — fill in the API key there.
APP_LIGHTRAG_ENABLED=true
APP_LIGHTRAG_BASE_URL=http://localhost:9621
# Docker app container uses this value if you run the backend through docker compose.
APP_LIGHTRAG_DOCKER_BASE_URL=http://lightrag:9621
APP_LIGHTRAG_API_KEY=
APP_LIGHTRAG_MODE=mix
